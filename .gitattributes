# Define macros (only works in top-level .gitattributes files)
# These macros are used by makekoi-client/.gitattributes.
# Git requires macro definitions to live in the top-level .gitattributes,
# otherwise it prints "not allowed" warnings on every commit.
[attr]lfs               filter=lfs diff=lfs merge=lfs -text
[attr]unity-json        eol=lf linguist-language=json
[attr]unity-yaml        merge=unityyamlmerge eol=lf linguist-language=yaml
